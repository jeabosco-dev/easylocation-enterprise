rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- FONCTIONS DE BASE ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // Vérification basée sur les Custom Claims (token role)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role.upper() == 'ADMIN' || 
        request.auth.token.role.upper() == 'SUPER_ADMIN'
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.role.upper() == 'SUPER_ADMIN';
    }

    // --- RÈGLES PAR DOSSIER ---

    // 1. Profils (Photos d'utilisateurs)
    match /profils/{fileName} {
      allow read: if true;
      // Permet l'écriture si c'est l'admin ou si le début du nom de fichier est l'UID de l'utilisateur
      allow write, delete: if isAdmin() || (isAuthenticated() && fileName.startsWith(request.auth.uid));
    }

    // 2. Propriétés (Images des biens immobiliers - EasyLocation Enterprise)
    match /proprietes/{bailleurId}/{propertyId}/{allPaths=**} {
      allow read: if true; 
      allow write, delete: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == bailleurId &&
        (request.method == 'DELETE' || (
          request.resource.size < 10 * 1024 * 1024 && // Augmenté à 10MB pour plus de souplesse
          request.resource.contentType.matches('image/.*')
        ))
      );
    }

    // 3. Dossier utilisateur générique
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // 4. Paiements et Preuves (Dossiers critiques pour les transactions)
    // Fusion des règles pour 'paiements' et 'preuves'
    match /{folder}/{userId}/{fileName} {
      allow read, write, delete: if folder in ['paiements', 'preuves'] && (
        isAdmin() || (
          isAuthenticated() && 
          request.auth.uid == userId &&
          (request.method == 'GET' || request.method == 'DELETE' || request.resource.contentType.matches('image/.*'))
        )
      );
    }

    // 5. Documents confidentiels (Identité)
    match /identite_verif/{userId}/{allPaths=**} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write, delete: if (isAuthenticated() && request.auth.uid == userId) || isSuperAdmin();
    }

    // 6. Sécurité par défaut (Tout le reste)
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write, delete: if isSuperAdmin();
    }
  }
}