rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'ADMIN' || 
        request.auth.token.role == 'admin' || 
        request.auth.token.role == 'SUPER_ADMIN' || 
        request.auth.token.role == 'super_admin'
      );
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'SUPER_ADMIN' || 
        request.auth.token.role == 'super_admin'
      );
    }

    // 1. Profils
    match /profils/{fileName} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == fileName.replace('.jpg', '').replace('.png', ''));
    }

    // 2. Propriétés
    match /proprietes/{bailleurId}/{propertyId}/{allPaths=**} {
      allow read: if true; 
      allow write: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == bailleurId &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*')
      );
    }

    // 3. Dossier utilisateur générique
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // 4. Preuves de Paiement (INDISPENSABLE pour ton widget)
    match /preuves/{userId}/{fileName} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAdmin() || (
        isAuthenticated() && 
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB pour les captures de haute qualité
        request.resource.contentType.matches('image/.*')
      );
    }

    // 5. Documents confidentiels
    match /identite_verif/{userId}/{allPaths=**} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if (isAuthenticated() && request.auth.uid == userId) || isSuperAdmin();
    }

    // 6. Sécurité par défaut
    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}