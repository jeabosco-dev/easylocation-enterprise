rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Récupère les données complètes pour vérifier les rôles complexes
    function getUserData() {
      return get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        data.role in ['ADMIN', 'admin', 'SUPER_ADMIN', 'super_admin'] ||
        (data.roles != null && data.roles.hasAny(['ADMIN', 'admin', 'SUPER_ADMIN', 'super_admin']))
      );
    }

    function isSuperAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        data.role in ['SUPER_ADMIN', 'super_admin'] ||
        (data.roles != null && data.roles.hasAny(['SUPER_ADMIN', 'super_admin']))
      );
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. UTILISATEURS (ACCÈS LOGIN SÉCURISÉ) ---
    match /utilisateurs/{userId} {
      // ✅ CORRECTION ICI : 
      // allow get: permet de lire un profil si on connaît son ID (nécessaire pour le login)
      // allow list: permet la recherche par numéro de téléphone (via getUserByPhoneNumber)
      allow get: if true; 
      allow list: if isSignedIn() || (request.query.limit == 1);
      
      // ✅ Création : Autorisé pour soi-même
      allow create: if isSignedIn() && request.auth.uid == userId;

      // ✅ Mise à jour : Admin peut tout faire, l'user peut changer tout SAUF ses rôles/blocage
      allow update: if isSuperAdmin() || 
                    (isUser(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'isBlocked'])) || 
                    (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'isBlocked']));
      
      allow delete: if isSuperAdmin();

      match /favoris/{favoriId} { allow read, write: if isUser(userId) || isAdmin(); }
      match /alertes/{alerteId} { allow read, write: if isUser(userId) || isAdmin(); }
    }

    // --- 2. PROFILS SPÉCIFIQUES ---
    match /user_profiles/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isAdmin(); }
    match /bailleurs/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isAdmin(); }
    match /locataires/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isAdmin(); }

    // --- 3. INDEX TÉLÉPHONE (CRUCIAL POUR LE LOGIN) ---
    match /phone_index/{phone} {
      allow read: if true; // Permet de vérifier si le numéro existe avant le login
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(); 
    }

    // --- 4. PROPRIÉTÉS ---
    match /proprietes/{propertyId} {
      allow read: if true; 
      allow create: if (isSignedIn() && request.resource.data.bailleurId == request.auth.uid) || isAdmin();
      allow update: if isAdmin() || (isSignedIn() && (
        resource.data.bailleurId == request.auth.uid || 
        (resource.data.status == 'published' && request.resource.data.status == 'en_cours_de_reservation' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'currentReservedBy'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoriteCount', 'shares', 'views']))
      ));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.bailleurId == request.auth.uid);

      match /viewers/{viewerId} { allow read, write: if isSignedIn() || isAdmin(); }
      match /comments/{commentId} {
        allow read: if true; allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // --- 5. RÉSERVATIONS & DEMANDES ---
    match /reservations/{resId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /demandes_visites/{demandeId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin() || (isSignedIn() && (
        (exists(resource.data) && (resource.data.bailleurId == request.auth.uid || resource.data.locataireId == request.auth.uid)) ||
        (!exists(resource.data) && request.resource.data.locataireId == request.auth.uid)
      ));
    }
    match /demandes/{demandeId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin() || (isSignedIn() && (resource.data.bailleurId == request.auth.uid || resource.data.locataireId == request.auth.uid));
    }

    // --- 6. PAIEMENTS & FACTURES ---
    match /paiements/{paiementId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.statut == 'en_attente') || isAdmin();
      allow update, delete: if isAdmin();
    }
    match /factures/{factureId} {
      allow read: if (isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.telClient == request.auth.token.phone_number)) || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin(); 
    }

    // --- 7. SIGNALEMENTS & HISTORIQUES ---
    match /abus_signalement/{reportId} { allow create: if isSignedIn(); allow read, update, delete: if isAdmin(); }
    match /historique_locataire/{userId}/{document=**} { allow read, write: if isUser(userId) || isAdmin(); }
    match /journal_activites/{activityId} {
      allow create: if isSignedIn();
      allow read: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();
      allow delete: if isSuperAdmin(); 
    }

    // --- 11. CONFIG & PARAMÈTRES ---
    match /app_config/{configId} { allow read: if true; allow write: if isSuperAdmin(); }
    match /settings/{docId} { allow read: if isSignedIn() || isAdmin(); allow write: if isSuperAdmin(); }
    match /notifications/{notifId} { allow create, read: if isSignedIn() || isAdmin(); allow delete: if isSuperAdmin(); }

    // --- 12. LOGS D'AUDIT ---
    match /admin_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // --- DÉFAUT ---
    match /{document=**} { 
      allow read, write: if isSuperAdmin(); 
    }
  }
}