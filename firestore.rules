rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/utilisateurs/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.role in ['AGENT', 'SUPER_ADMIN', 'agent', 'super_admin'] ||
        (userDocExists() && (
          getUserData().role in ['AGENT', 'SUPER_ADMIN', 'agent', 'super_admin'] ||
          (getUserData().roles != null && getUserData().roles.hasAny(['AGENT', 'SUPER_ADMIN', 'agent', 'super_admin']))
        ))
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.role in ['SUPER_ADMIN', 'super_admin'] ||
        (userDocExists() && (
          getUserData().role in ['SUPER_ADMIN', 'super_admin'] ||
          (getUserData().roles != null && getUserData().roles.hasAny(['SUPER_ADMIN', 'super_admin']))
        ))
      );
    }

    function isInDepartment(dept) {
      return isStaff() && userDocExists() && (
        getUserData().direction == dept.toUpperCase() || 
        getUserData().direction == dept.toLowerCase()
      );
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ==========================================
    // ---            RÈGLES PAR COLLECTION       ---
    // ==========================================

    match /status_activite/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid in request.resource.data.consultants_ids);
      allow delete: if isSuperAdmin();
    }

    match /community_goals/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /app_config/{configId} { 
      allow read: if true; 
      allow write: if isSuperAdmin(); 
    }

    match /utilisateurs/{userId} {
      allow get: if true; 
      allow list: if isSignedIn() || (request.query.limit == 1);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSuperAdmin() || 
                      (isInDepartment('DIRECTION GÉNÉRALE') || isInDepartment('RH')) ||
                      (isUser(userId) && (
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'direction', 'roles', 'isBlocked', 'statut', 'staffStatus']) 
                        ||
                        (request.resource.data.activeRole in ['locataire', 'bailleur', 'AGENT', 'SUPER_ADMIN', 'OPERATIONS', 'FINANCE', 'LOGISTIQUE', 'agent', 'super_admin'])
                      ));
      allow delete: if isSuperAdmin();

      match /favoris/{favoriId} { allow read, write: if isUser(userId) || isStaff(); }
      match /alertes/{alerteId} { allow read, write: if isUser(userId) || isStaff(); }
    }

    match /user_profiles/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isStaff(); }
    match /bailleurs/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isStaff(); }
    match /locataires/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isStaff(); }

    match /phone_index/{phone} {
      allow read: if true; 
      allow create, update: if isSignedIn();
      allow delete: if isStaff(); 
    }

    match /proprietes/{propertyId} {
      allow read: if true; 
      allow create: if (isSignedIn() && request.resource.data.bailleurId == request.auth.uid) || isInDepartment('OPERATIONS') || isSuperAdmin();
      
      allow update: if isSuperAdmin() || isInDepartment('OPERATIONS') || (isSignedIn() && (
        resource.data.bailleurId == request.auth.uid || 
        resource.data.clientId == request.auth.uid || 
        request.resource.data.status == 'en_attente_paiement' ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'favoriteCount', 'shares', 'views', 'nbVues', 'status', 'estLouee', 
          'rentedAt', 'currentReservedBy', 'lockTimestamp', 'clientId', 'lockedBy', 'updatedAt'
        ])
      ));
      
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.bailleurId == request.auth.uid);

      match /shards/{shardId} {
        allow read: if true;
        allow write: if isSignedIn(); 
      }

      match /viewers/{viewerId} { allow read, write: if isSignedIn() || isStaff(); }
      match /comments/{commentId} {
        allow read: if true; allow create: if isSignedIn();
        allow update, delete: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /stats_localites/{localiteId} {
      allow read: if true; 
      allow write: if isStaff(); 
    }

    match /stats_locales/{villeId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isInDepartment('DIRECTION GÉNÉRALE') || isInDepartment('OPERATIONS');
    }

    match /reservations/{resId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isInDepartment('OPERATIONS') || isSuperAdmin();
      allow update, delete: if isSuperAdmin() || isInDepartment('OPERATIONS') || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /factures/{factureId} {
      allow read: if isStaff() || (isSignedIn() && (
        resource == null ||
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid) ||
        (resource.data.tenantId != null && resource.data.tenantId == request.auth.uid) ||
        (resource.data.locataireId != null && resource.data.locataireId == request.auth.uid) ||
        (resource.data.bailleurId != null && resource.data.bailleurId == request.auth.uid) ||
        (resource.data.agentTerrainId != null && resource.data.agentTerrainId == request.auth.uid)
      ));
      
      allow create, update: if isSignedIn(); 
      allow delete: if isSuperAdmin();
    }

    match /contrats/{contratId} {
      allow read: if isStaff() || (isSignedIn() && (
        resource.data.locataireId == request.auth.uid || 
        resource.data.bailleurId == request.auth.uid
      ));

      allow create: if isSuperAdmin() || isInDepartment('OPERATIONS') || (isSignedIn() && (
        request.resource.data.locataireId == request.auth.uid || 
        request.resource.data.bailleurId == request.auth.uid
      ));

      allow update: if isSuperAdmin() || isInDepartment('OPERATIONS') || (
        isSignedIn() && 
        (resource.data.locataireId == request.auth.uid || resource.data.bailleurId == request.auth.uid) &&
        request.resource.data.locataireId == resource.data.locataireId &&
        request.resource.data.bailleurId == resource.data.bailleurId
      );

      allow delete: if isSuperAdmin();
    }

    match /services_commandes/{serviceId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isSuperAdmin() || isInDepartment('OPERATIONS') || isInDepartment('FINANCE');
      allow delete: if isSuperAdmin();
    }

    match /pending_payments/{paymentId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isStaff());
      allow create: if isSignedIn();
      allow update: if isStaff() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    match /wallets/{userId} {
      allow read: if isUser(userId) || isSuperAdmin() || isInDepartment('FINANCE') || isInDepartment('OPERATIONS');
      allow update: if isSuperAdmin() || isInDepartment('FINANCE') || isInDepartment('OPERATIONS');
      allow create: if isUser(userId) || isSuperAdmin() || isInDepartment('FINANCE');
    }

    match /transactions/{txId} {
      allow read: if isSuperAdmin() || isInDepartment('FINANCE') || isInDepartment('OPERATIONS') || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.walletId == request.auth.uid
      ));
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.walletId == request.auth.uid);
      allow update, delete: if false; 
    }

    match /refund_requests/{requestId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'en_attente';
      allow update: if isSuperAdmin() || isInDepartment('FINANCE');
      allow delete: if isSuperAdmin();
    }

    match /paiements/{paiementId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.statut == 'en_attente') || isSuperAdmin() || isInDepartment('FINANCE');
      allow update, delete: if isSuperAdmin() || isInDepartment('FINANCE') || isInDepartment('OPERATIONS');
    }

    match /payment_requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /abus_signalement/{reportId} { allow create: if isSignedIn(); allow read, update, delete: if isStaff(); }
    
    match /historique_locataire/{userId}/user_history/{document} {
      allow read, write: if isSignedIn() && (isUser(userId) || isStaff());
    }

    match /journal_activites/{activityId} {
      allow create: if isSignedIn();
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow delete: if isSuperAdmin(); 
    }

    match /sessions_equipe/{sessionId} {
      allow read: if isStaff();
      allow write: if isSuperAdmin() || isInDepartment('DIRECTION GÉNÉRALE') || isInDepartment('RH');
    }

    match /settings/app_config { allow read: if true; }
    match /settings/{docId} { 
      allow read: if isStaff(); 
      allow write: if isSuperAdmin(); 
    }
    match /notifications/{notifId} { allow create, read: if isSignedIn() || isStaff(); allow delete: if isSuperAdmin(); }

    match /admin_logs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if false;
    }

    match /{document=**} { 
      allow read, write: if isSuperAdmin(); 
    }
  }
}