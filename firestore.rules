rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE SÉCURITÉ CENTRALISÉES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/utilisateurs/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDocExists() && (
        getUserData().role in ['ADMIN', 'admin', 'SUPER_ADMIN', 'super_admin'] ||
        (getUserData().roles != null && getUserData().roles.hasAny(['ADMIN', 'admin', 'SUPER_ADMIN', 'super_admin']))
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && userDocExists() && (
        getUserData().role in ['SUPER_ADMIN', 'super_admin'] ||
        (getUserData().roles != null && getUserData().roles.hasAny(['SUPER_ADMIN', 'super_admin']))
      );
    }

    // ✅ AJUSTEMENT RECRUTEMENT TOP-DOWN : Inclut le rôle 'operations' attribué en direct
    function isAgentCCV() {
      return isSignedIn() && userDocExists() && (
        getUserData().role in ['agent_ccv', 'ccv', 'AGENT_CCV', 'operations'] ||
        (getUserData().roles != null && getUserData().roles.hasAny(['agent_ccv', 'ccv', 'AGENT_CCV', 'operations']))
      );
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 0. CONFIGURATION ---
    match /config/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /app_config/{configId} { 
      allow read: if true; 
      allow write: if isSuperAdmin(); 
    }

    // --- 1. UTILISATEURS ---
    match /utilisateurs/{userId} {
      allow get: if true; 
      allow list: if isSignedIn() || (request.query.limit == 1);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSuperAdmin() || 
                    (isUser(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'isBlocked'])) || 
                    (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'isBlocked']));
      allow delete: if isSuperAdmin();

      match /favoris/{favoriId} { allow read, write: if isUser(userId) || isAdmin(); }
      match /alertes/{alerteId} { allow read, write: if isUser(userId) || isAdmin(); }
    }

    // --- 2. PROFILS SPÉCIFIQUES ---
    match /user_profiles/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isAdmin(); }
    match /bailleurs/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isAdmin(); }
    match /locataires/{userId} { allow read: if isSignedIn(); allow create, update: if isUser(userId) || isAdmin(); }

    // --- 3. INDEX TÉLÉPHONE (CORRIGÉ) ---
    match /phone_index/{phone} {
      // Permet de vérifier publiquement si un numéro possède déjà un compte avant connexion
      allow read: if true; 
      
      // Permet à tout utilisateur authentifié d'enregistrer ou de mettre à jour son propre index
      allow create, update: if isSignedIn();
      
      // La suppression reste réservée aux administrateurs
      allow delete: if isAdmin(); 
    }

    // --- 4. PROPRIÉTÉS ---
    match /proprietes/{propertyId} {
      allow read: if true; 
      allow create: if (isSignedIn() && request.resource.data.bailleurId == request.auth.uid) || isAdmin();
      allow update: if isAdmin() || isAgentCCV() || (isSignedIn() && (
        resource.data.bailleurId == request.auth.uid || 
        (resource.data.status == 'published' && request.resource.data.status == 'en_cours_de_reservation' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'currentReservedBy'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoriteCount', 'shares', 'views', 'nbVues']))
      ));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.bailleurId == request.auth.uid);

      match /shards/{shardId} {
        allow read: if true;
        allow write: if isSignedIn(); 
      }

      match /viewers/{viewerId} { allow read, write: if isSignedIn() || isAdmin(); }
      match /comments/{commentId} {
        allow read: if true; allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // --- 4b. STATISTIQUES DES LOCALITÉS ---
    match /stats_localites/{localiteId} {
      allow read: if true; 
      allow write: if isSignedIn() || isAdmin() || isSuperAdmin(); 
    }

    // --- 4c. STATISTIQUES LOCALES ---
    match /stats_locales/{villeId} {
      allow read: if true;
      allow write: if isAdmin() || isSuperAdmin();
    }

    // --- 5. RÉSERVATIONS & DEMANDES ---
    match /reservations/{resId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- 6. FACTURES & CONTRATS (ORCHESTRATION PHYGITALE) ---
    match /factures/{factureId} {
      // ✅ SYNCHRONISATION DES REQUÊTES DU LOG : Autorise le client (tenantId ou clientId) et les rôles opérationnels
      allow read: if isAdmin() || isAgentCCV() || (isSignedIn() && (
        (resource.data.clientId != null && resource.data.clientId == request.auth.uid) ||
        (resource.data.tenantId != null && resource.data.tenantId == request.auth.uid) ||
        (resource.data.locataireId != null && resource.data.locataireId == request.auth.uid)
      ));
      
      // ✅ ALIGNEMENT MODÈLE DART : Utilisation définitive de agentTerrainId à la place d'agentId
      allow update: if isSuperAdmin() || 
                    (isAdmin() && request.auth.uid == resource.data.assignedAdminId) ||
                    (isAgentCCV() && request.auth.uid == resource.data.agentTerrainId);
                    
      allow create: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /contrats/{contratId} {
      allow read: if isSignedIn() && (
        resource.data.locataireId == request.auth.uid || 
        resource.data.bailleurId == request.auth.uid ||
        resource.data.locataireId == request.auth.phoneNumber || 
        isAdmin() ||
        isAgentCCV()
      );

      allow create: if isSignedIn() && (
        request.resource.data.locataireId == request.auth.uid || 
        request.resource.data.locataireId == request.auth.phoneNumber ||
        request.resource.data.bailleurId == request.auth.uid ||
        isAdmin() ||
        isAgentCCV()
      );

      allow update: if isAdmin() || isAgentCCV() || (
        isSignedIn() && 
        (resource.data.locataireId == request.auth.uid || resource.data.bailleurId == request.auth.uid || resource.data.locataireId == request.auth.phoneNumber) &&
        request.resource.data.locataireId == resource.data.locataireId &&
        request.resource.data.bailleurId == resource.data.bailleurId
      );

      allow delete: if isSuperAdmin() || (
        isSignedIn() && 
        (resource.data.locataireId == request.auth.uid || resource.data.bailleurId == request.auth.uid)
      );
    }

    // --- 7. SYSTÈME FINANCIER & SERVICES ---
    match /services/{serviceId} {
      allow read: if (isSignedIn() && resource.data.locataireId == request.auth.uid) || isAdmin() || isAgentCCV();
      allow create: if isSignedIn() && request.resource.data.locataireId == request.auth.uid;
      allow update: if isAdmin() || isAgentCCV();
      allow delete: if isSuperAdmin();
    }

    match /wallets/{userId} {
      allow read: if isUser(userId) || isAdmin() || isAgentCCV();
      allow update: if isAdmin() || isAgentCCV(); 
      allow create: if isUser(userId) || isAdmin();
    }

    match /transactions/{txId} {
      // ✅ OUVERTURE DE LECTURE : L'utilisateur pour son portefeuille, ou le staff métier pour valider l'historique
      allow read: if isAdmin() || isAgentCCV() || (isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.walletId == request.auth.uid
      ));
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || request.resource.data.walletId == request.auth.uid);
      allow update, delete: if false; 
    }

    match /refund_requests/{requestId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin() || isAgentCCV();
      allow create: if isSignedIn() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status == 'en_attente';
      allow update: if isAdmin() || isAgentCCV();
      allow delete: if isSuperAdmin();
    }

    match /paiements/{paiementId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin() || isAgentCCV();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.statut == 'en_attente') || isAdmin() || isAgentCCV();
      allow update, delete: if isAdmin() || isAgentCCV();
    }

    match /payment_requests/{requestId} {
      allow read: if isSignedIn(); // Permet les écoutes de requêtes de paiement en attente sans restrictions bloquantes
      allow write: if isSignedIn();
    }

    // --- 8. SIGNALEMENTS & FEEDBACKS ---
    match /abus_signalement/{reportId} { allow create: if isSignedIn(); allow read, update, delete: if isAdmin() || isAgentCCV(); }
    
    // ✅ CORRECTION LOGS HISTORIQUE : Autorise la lecture de l'historique de l'utilisateur concerné ou du staff
    match /historique_locataire/{userId}/user_history/{document} {
      allow read, write: if isSignedIn() && (isUser(userId) || isAdmin() || isAgentCCV());
    }

    match /journal_activites/{activityId} {
      allow create: if isSignedIn();
      allow read: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin() || isAgentCCV();
      allow delete: if isSuperAdmin(); 
    }

    // --- 8b. MANAGEMENT & SESSIONS ÉQUIPE ---
    match /sessions_equipe/{sessionId} {
      // ✅ Résout l'erreur de synchronisation pour l'équipe (Accessible au staff admin et opérations)
      allow read: if isAdmin() || isAgentCCV();
      allow write: if isAdmin();
    }

    // --- 9. PARAMÈTRES & NOTIFICATIONS ---
    match /settings/app_config { allow read: if true; }
    match /settings/{docId} { 
      allow read: if isSignedIn() || isAdmin() || isAgentCCV(); 
      allow write: if isSuperAdmin(); 
    }
    match /notifications/{notifId} { allow create, read: if isSignedIn() || isAdmin() || isAgentCCV(); allow delete: if isSuperAdmin(); }

    // --- 10. LOGS D'AUDIT ---
    match /admin_logs/{logId} {
      allow read, create: if isAdmin() || isAgentCCV();
      allow update, delete: if false;
    }

    // --- DÉFAUT ---
    match /{document=**} { 
      allow read, write: if isSuperAdmin(); 
    }
  }
}